# ────────────────────────────────────────────────────────────────────
# AI Interview Platform — Frontend Environment Variables
# Copy this to .env and fill in your values
# ────────────────────────────────────────────────────────────────────

# Your backend FastAPI server URL
# For local development: use your machine's local IP (not localhost!)
# Find your IP: run `ipconfig` on Windows, look for IPv4 Address
EXPO_PUBLIC_API_URL=http://192.168.1.100:8000

# Example if using Docker on same machine:
# EXPO_PUBLIC_API_URL=http://10.0.2.2:8000  (Android emulator)
# EXPO_PUBLIC_API_URL=http://localhost:8000  (iOS simulator)
