{
  "expo": {
    "name": "AI Interview Platform",
    "slug": "ai-interview-platform",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "aiinterview",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0f1a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aiinterview.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "We need microphone access for voice interviews.",
        "NSDocumentsFolderUsageDescription": "We need access to upload your resume."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0f0f1a"
      },
      "package": "com.aiinterview.app",
      "permissions": [
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "Allow AI Interview Platform to access your microphone for voice interviews."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
