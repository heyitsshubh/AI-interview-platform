# ╔══════════════════════════════════════════════════════════════════════╗
# ║           AI INTERVIEW PLATFORM — ENVIRONMENT VARIABLES             ║
# ║  Copy this file to .env and fill in your actual values              ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME="AI Interview Platform"
APP_VERSION="1.0.0"
DEBUG=false

# ─── PostgreSQL Database ──────────────────────────────────────────────────────
POSTGRES_PASSWORD=securepassword123
DATABASE_URL=postgresql+asyncpg://postgres:securepassword123@postgres:5432/ai_interview
# For local dev (without Docker):
# DATABASE_URL=postgresql+asyncpg://postgres:securepassword123@localhost:5432/ai_interview

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
# For local dev:
# REDIS_HOST=localhost

# ─── JWT Authentication ───────────────────────────────────────────────────────
# IMPORTANT: Change this to a long, random secret in production!
JWT_SECRET_KEY=your-super-secret-jwt-key-at-least-32-characters-long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Internal API Security ────────────────────────────────────────────────────
# Key used by Node.js worker to call FastAPI internal endpoints
INTERNAL_API_KEY=internal-secret-key-change-in-production

# ─── Google Gemini AI ─────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ─── OpenAI (Embeddings Only) ─────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# ─── Google Cloud Speech-to-Text ─────────────────────────────────────────────
# Path to Google service account JSON credentials file
# Download from: https://console.cloud.google.com/iam-admin/serviceaccounts
GOOGLE_APPLICATION_CREDENTIALS=/app/google-credentials.json

# ─── SMTP Email ───────────────────────────────────────────────────────────────
# Gmail SMTP (App Password required — not your regular Gmail password)
# Enable App Passwords: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM=noreply@ai-interview.com
SMTP_FROM_NAME="AI Interview Platform"

# ─── Local Storage ────────────────────────────────────────────────────────────
STORAGE_PATH=./storage

# ─── CORS (Frontend URL) ──────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:3000"]
FRONTEND_URL=http://localhost:3000

# ─── Worker Settings ─────────────────────────────────────────────────────────
API_BASE_URL=http://backend:8000
# For local dev worker:
# API_BASE_URL=http://localhost:8000

# ─── Node Environment ─────────────────────────────────────────────────────────
NODE_ENV=production
